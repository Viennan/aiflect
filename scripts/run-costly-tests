#!/usr/bin/env python3.12
from __future__ import annotations

import argparse
from collections.abc import Iterable, Mapping
from dataclasses import dataclass
import json
import os
from pathlib import Path
import subprocess
import sys
from typing import Any


REPO_ROOT = Path(__file__).resolve().parents[1]
DEFAULT_CONFIG = REPO_ROOT / "creds.json"


@dataclass(frozen=True, slots=True)
class SelectedCase:
    provider: str
    feature: str
    profile: str
    model_id: str
    api_key_env: str | None


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Run costly tests with explicit consent and creds.json selection.",
    )
    parser.add_argument("--config", default=str(DEFAULT_CONFIG), help="Path to creds.json.")
    parser.add_argument("--provider", action="append", default=[], help="Provider to include. Can be repeated.")
    parser.add_argument("--feature", action="append", default=[], help="Feature to include. Can be repeated.")
    parser.add_argument("--profile", action="append", default=[], help="Model profile to include. Defaults to cheap.")
    parser.add_argument("--all-models", action="store_true", help="Run all enabled model profiles.")
    parser.add_argument("--yes", action="store_true", help="Confirm costly API usage non-interactively.")
    parser.add_argument(
        "--pytest-arg",
        action="append",
        default=[],
        help="Additional argument passed through to pytest. Use --pytest-arg=-q for option values.",
    )
    parser.add_argument(
        "pytest_args",
        nargs=argparse.REMAINDER,
        help="Arguments after -- are passed through to pytest.",
    )
    args = parser.parse_args()

    config_path = _resolve_config_path(args.config)
    config = _load_config(config_path)
    selected = _select_cases(
        config,
        providers=set(args.provider),
        features=set(args.feature),
        profiles=None if args.all_models else set(args.profile or ["cheap"]),
    )
    if not selected:
        print("No enabled costly model cases matched the requested selection.", file=sys.stderr)
        return 2

    missing_envs = sorted({case.api_key_env for case in selected if case.api_key_env and not os.environ.get(case.api_key_env)})
    if missing_envs:
        print("Missing required API key environment variables:", file=sys.stderr)
        for env_name in missing_envs:
            print(f"  - {env_name}", file=sys.stderr)
        return 2

    _print_selection(selected, config_path)
    if not args.yes and not _confirm():
        print("Costly test run cancelled.")
        return 1

    command = _pytest_command(args, config_path)
    sys.stdout.flush()
    env = dict(os.environ)
    env["AIFLECT_COSTLY_RUNNER"] = "1"
    return subprocess.run(command, cwd=REPO_ROOT / "python", env=env, check=False).returncode


def _resolve_config_path(path_text: str) -> Path:
    path = Path(path_text)
    return path if path.is_absolute() else REPO_ROOT / path


def _load_config(path: Path) -> dict[str, Any]:
    if not path.exists():
        print(f"Costly config file not found: {path}", file=sys.stderr)
        raise SystemExit(2)
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        print(f"Invalid costly config JSON: {path}: {exc}", file=sys.stderr)
        raise SystemExit(2) from exc
    if not isinstance(data, dict):
        print("Costly config root must be a JSON object.", file=sys.stderr)
        raise SystemExit(2)
    _reject_inline_secrets(data)
    return data


def _reject_inline_secrets(value: Any, *, path: str = "$") -> None:
    if isinstance(value, Mapping):
        for key, item in value.items():
            key_text = str(key)
            lowered = key_text.lower()
            if lowered in {"api_key", "apikey", "secret", "token", "access_token"}:
                print(
                    f"Costly config must use environment variables instead of {path}.{key_text}.",
                    file=sys.stderr,
                )
                raise SystemExit(2)
            _reject_inline_secrets(item, path=f"{path}.{key_text}")
    elif isinstance(value, list):
        for index, item in enumerate(value):
            _reject_inline_secrets(item, path=f"{path}[{index}]")


def _select_cases(
    config: Mapping[str, Any],
    *,
    providers: set[str],
    features: set[str],
    profiles: set[str] | None,
) -> list[SelectedCase]:
    cases: list[SelectedCase] = []
    provider_map = config.get("providers", {})
    if not isinstance(provider_map, Mapping):
        return cases
    for provider, provider_raw in sorted(provider_map.items()):
        if providers and provider not in providers:
            continue
        if not isinstance(provider_raw, Mapping) or not provider_raw.get("enabled", False):
            continue
        feature_map = provider_raw.get("features", {})
        if not isinstance(feature_map, Mapping):
            continue
        api_key_env = provider_raw.get("api_key_env")
        for feature, feature_raw in sorted(feature_map.items()):
            if features and feature not in features:
                continue
            if not isinstance(feature_raw, Mapping):
                continue
            for model_raw in feature_raw.get("models", ()) or ():
                if not isinstance(model_raw, Mapping) or not model_raw.get("enabled", False):
                    continue
                model_id = model_raw.get("id")
                if not isinstance(model_id, str) or not model_id:
                    continue
                profile = str(model_raw.get("profile") or "default")
                if profiles is not None and profile not in profiles:
                    continue
                cases.append(
                    SelectedCase(
                        provider=str(provider),
                        feature=str(feature),
                        profile=profile,
                        model_id=model_id,
                        api_key_env=api_key_env if isinstance(api_key_env, str) else None,
                    )
                )
    return cases


def _print_selection(selected: Iterable[SelectedCase], config_path: Path) -> None:
    print("Costly tests may call paid provider APIs.")
    print(f"Config: {config_path}")
    print("Selected model cases:")
    for case in selected:
        print(f"  - provider={case.provider} feature={case.feature} profile={case.profile} model={case.model_id}")


def _confirm() -> bool:
    answer = input("Continue? [y/N] ").strip().lower()
    return answer in {"y", "yes"}


def _pytest_command(args: argparse.Namespace, config_path: Path) -> list[str]:
    python_executable = REPO_ROOT / ".venv" / "bin" / "python"
    command = [
        str(python_executable if python_executable.exists() else Path(sys.executable)),
        "-m",
        "pytest",
        "tests/costly",
        "--run-costly",
        "--costly-config",
        str(config_path),
    ]
    for provider in args.provider:
        command.extend(["--provider", provider])
    for feature in args.feature:
        command.extend(["--feature", feature])
    for profile in args.profile:
        command.extend(["--profile", profile])
    if args.all_models:
        command.append("--all-costly-models")
    command.extend(args.pytest_arg)
    passthrough_args = list(args.pytest_args)
    if passthrough_args[:1] == ["--"]:
        passthrough_args = passthrough_args[1:]
    command.extend(passthrough_args)
    return command


if __name__ == "__main__":
    raise SystemExit(main())
