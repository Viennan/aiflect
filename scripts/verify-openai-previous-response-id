#!/usr/bin/env python3.12
from __future__ import annotations

import argparse
from collections.abc import Mapping
from dataclasses import dataclass
import json
import os
from pathlib import Path
import subprocess
import sys
from typing import Any
from uuid import uuid4


REPO_ROOT = Path(__file__).resolve().parents[1]
DEFAULT_CONFIG = REPO_ROOT / "creds.json"
_CHILD_ENV = "VATBRAIN_OPENAI_PREVIOUS_RESPONSE_ID_CHILD"


@dataclass(frozen=True, slots=True)
class OpenAIModelCase:
    model_id: str
    profile: str


def main() -> int:
    _reexec_with_project_venv()

    parser = argparse.ArgumentParser(
        description=(
            "Verify whether the OpenAI Responses API configured in creds.json "
            "supports previous_response_id chained multi-turn requests."
        ),
    )
    parser.add_argument("--config", default=str(DEFAULT_CONFIG), help="Path to creds.json.")
    parser.add_argument("--model", action="append", default=[], help="OpenAI model id to verify. Can be repeated.")
    parser.add_argument("--profile", action="append", default=[], help="Model profile to include. Can be repeated.")
    parser.add_argument("--yes", action="store_true", help="Confirm costly API usage non-interactively.")
    parser.add_argument(
        "--max-output-tokens",
        type=int,
        default=64,
        help="max_output_tokens used for both verification requests.",
    )
    args = parser.parse_args()

    config_path = _resolve_config_path(args.config)
    config = _load_config(config_path)
    provider = _openai_provider_config(config)
    selected = _select_openai_models(
        provider,
        models=set(args.model),
        profiles=set(args.profile),
    )
    if not selected:
        print("No enabled OpenAI generation model cases matched the requested selection.", file=sys.stderr)
        return 2

    api_key_env = provider.get("api_key_env")
    if not isinstance(api_key_env, str) or not api_key_env:
        print("OpenAI provider has no api_key_env configured.", file=sys.stderr)
        return 2
    api_key = os.environ.get(api_key_env)
    if not api_key:
        print(f"Missing required API key environment variable: {api_key_env}", file=sys.stderr)
        return 2

    _print_selection(config_path, provider, selected, api_key_env)
    sys.stdout.flush()
    if not args.yes and not _confirm():
        print("Verification cancelled.")
        return 1

    try:
        from openai import OpenAI
    except Exception as exc:
        print("The openai package is required. Install python[test] in the project venv.", file=sys.stderr)
        print(f"Import error: {exc}", file=sys.stderr)
        return 2

    client = OpenAI(**_openai_client_options(provider, api_key=api_key))
    failures = 0
    for case in selected:
        if not _verify_model(
            client,
            case,
            max_output_tokens=args.max_output_tokens,
        ):
            failures += 1
    return 1 if failures else 0


def _reexec_with_project_venv() -> None:
    if os.environ.get(_CHILD_ENV) == "1":
        return
    venv_root = REPO_ROOT / ".venv"
    python_executable = REPO_ROOT / ".venv" / "bin" / "python"
    if not python_executable.exists():
        return
    if Path(sys.prefix).resolve() == venv_root.resolve():
        return
    env = dict(os.environ)
    env[_CHILD_ENV] = "1"
    raise SystemExit(
        subprocess.run(
            [str(python_executable), str(Path(__file__).resolve()), *sys.argv[1:]],
            cwd=REPO_ROOT,
            env=env,
            check=False,
        ).returncode
    )


def _resolve_config_path(path_text: str) -> Path:
    path = Path(path_text)
    return path if path.is_absolute() else REPO_ROOT / path


def _load_config(path: Path) -> dict[str, Any]:
    if not path.exists():
        print(f"Costly config file not found: {path}", file=sys.stderr)
        raise SystemExit(2)
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        print(f"Invalid costly config JSON: {path}: {exc}", file=sys.stderr)
        raise SystemExit(2) from exc
    if not isinstance(data, dict):
        print("Costly config root must be a JSON object.", file=sys.stderr)
        raise SystemExit(2)
    _reject_inline_secrets(data)
    return data


def _reject_inline_secrets(value: Any, *, path: str = "$") -> None:
    if isinstance(value, Mapping):
        for key, item in value.items():
            key_text = str(key)
            lowered = key_text.lower()
            if lowered in {"api_key", "apikey", "secret", "token", "access_token"}:
                print(
                    f"Costly config must use environment variables instead of {path}.{key_text}.",
                    file=sys.stderr,
                )
                raise SystemExit(2)
            _reject_inline_secrets(item, path=f"{path}.{key_text}")
    elif isinstance(value, list):
        for index, item in enumerate(value):
            _reject_inline_secrets(item, path=f"{path}[{index}]")


def _openai_provider_config(config: Mapping[str, Any]) -> Mapping[str, Any]:
    providers = config.get("providers", {})
    if not isinstance(providers, Mapping):
        print("creds.json providers must be a JSON object.", file=sys.stderr)
        raise SystemExit(2)
    provider = providers.get("openai")
    if not isinstance(provider, Mapping) or not provider.get("enabled", False):
        print("OpenAI provider is missing or disabled in creds.json.", file=sys.stderr)
        raise SystemExit(2)
    return provider


def _select_openai_models(
    provider: Mapping[str, Any],
    *,
    models: set[str],
    profiles: set[str],
) -> list[OpenAIModelCase]:
    features = provider.get("features", {})
    if not isinstance(features, Mapping):
        return []
    generation = features.get("generation", {})
    if not isinstance(generation, Mapping):
        return []

    selected: list[OpenAIModelCase] = []
    for model_raw in generation.get("models", ()) or ():
        if not isinstance(model_raw, Mapping) or not model_raw.get("enabled", False):
            continue
        model_id = model_raw.get("id")
        if not isinstance(model_id, str) or not model_id:
            continue
        profile = str(model_raw.get("profile") or "default")
        if models and model_id not in models:
            continue
        if profiles and profile not in profiles:
            continue
        selected.append(OpenAIModelCase(model_id=model_id, profile=profile))
    return selected


def _openai_client_options(provider: Mapping[str, Any], *, api_key: str) -> dict[str, Any]:
    options: dict[str, Any] = {"api_key": api_key}
    base_url = provider.get("base_url")
    if isinstance(base_url, str) and base_url:
        options["base_url"] = base_url
    for option_name in ("timeout", "max_retries"):
        if option_name in provider:
            options[option_name] = provider[option_name]
    extra_options = provider.get("client_options", {})
    if isinstance(extra_options, Mapping):
        options.update(dict(extra_options))
    return options


def _print_selection(
    config_path: Path,
    provider: Mapping[str, Any],
    selected: list[OpenAIModelCase],
    api_key_env: str,
) -> None:
    print("This diagnostic may call paid OpenAI-compatible Responses API endpoints.")
    print(f"Config: {config_path}")
    base_url = provider.get("base_url")
    if isinstance(base_url, str) and base_url:
        print(f"OpenAI base_url: {base_url}")
    print(f"API key env: {api_key_env}")
    print("Selected model cases:")
    for case in selected:
        print(f"  - provider=openai feature=generation profile={case.profile} model={case.model_id}")


def _confirm() -> bool:
    answer = input("Continue? [y/N] ").strip().lower()
    return answer in {"y", "yes"}


def _verify_model(client: Any, case: OpenAIModelCase, *, max_output_tokens: int) -> bool:
    marker = f"VATBRAIN-PREVIOUS-RESPONSE-{uuid4().hex[:8].upper()}"
    print(f"Verifying model={case.model_id} profile={case.profile}", flush=True)
    print("  creating first stored response...", flush=True)
    try:
        first = client.responses.create(
            model=case.model_id,
            input=(
                "Remember this exact marker for the next turn: "
                f"{marker}. Reply with exactly ACK."
            ),
            max_output_tokens=max_output_tokens,
            store=True,
        )
    except Exception as exc:
        print(f"  FAIL first request: {exc.__class__.__name__}: {_single_line(str(exc))}")
        return False

    first_response_id = _response_id(first)
    if first_response_id is None:
        print("  FAIL: first response did not include an id.")
        return False

    print("  creating second response with previous_response_id...", flush=True)
    try:
        second = client.responses.create(
            model=case.model_id,
            input="What exact marker did I ask you to remember? Reply with the marker only.",
            previous_response_id=first_response_id,
            max_output_tokens=max_output_tokens,
            store=True,
        )
    except Exception as exc:
        print(f"  FAIL second request: {exc.__class__.__name__}: {_single_line(str(exc))}")
        return False

    text = _response_text(second)
    if marker.lower() not in text.lower():
        print("  FAIL: second response did not recover the marker through previous_response_id.")
        print(f"  second_text={_single_line(text)}")
        return False
    print("  PASS: previous_response_id chained context is available.")
    return True


def _response_id(response: Any) -> str | None:
    response_id = getattr(response, "id", None)
    return response_id if isinstance(response_id, str) and response_id else None


def _response_text(response: Any) -> str:
    output_text = getattr(response, "output_text", None)
    if isinstance(output_text, str) and output_text:
        return output_text

    chunks: list[str] = []
    for item in getattr(response, "output", []) or []:
        for content in getattr(item, "content", []) or []:
            text = getattr(content, "text", None)
            if isinstance(text, str):
                chunks.append(text)
    return "".join(chunks)


def _single_line(text: str) -> str:
    return " ".join(text.split())


if __name__ == "__main__":
    raise SystemExit(main())
